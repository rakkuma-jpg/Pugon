<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pugon.Pages.RecipesPage"
             xmlns:model="clr-namespace:Pugon.Model"
             xmlns:viewmodel="clr-namespace:Pugon.ViewModel"
             x:DataType="viewmodel:RecipesViewModel"
             Title="Recipes">

    <StackLayout VerticalOptions="Center" HorizontalOptions="Center">

        <!-- Difficulty Buttons -->
        <HorizontalStackLayout Spacing="10" >
            <Button Text="Easy"
                    Command="{Binding NavigateToBreadsCommand}"
                    CommandParameter="Easy"
                    BackgroundColor="White"/>
            <Button Text="Medium"
                    Command="{Binding NavigateToBreadsCommand}"
                    CommandParameter="Medium"
                    BackgroundColor="White"/>
            <Button Text="Hard"
                    Command="{Binding NavigateToBreadsCommand}"
                    CommandParameter="Hard"
                    BackgroundColor="White"/>
        </HorizontalStackLayout>

    </StackLayout>

</ContentPage>