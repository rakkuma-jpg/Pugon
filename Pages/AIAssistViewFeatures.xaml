<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:Pugon.ViewModel"
             x:Class="Pugon.Pages.AIAssistViewFeatures"
             xmlns:local="clr-namespace:Pugon"
             xmlns:syncTheme="clr-namespace:Syncfusion.Maui.Themes;assembly=Syncfusion.Maui.Core"
             xmlns:aiAssist="clr-namespace:Syncfusion.Maui.AIAssistView;assembly=Syncfusion.Maui.AIAssistView"
             Title="TinapAI">
    <ContentPage.BindingContext>
        <viewmodel:AIAssistViewModel x:Name="viewModel"/>
    </ContentPage.BindingContext>

    <ContentPage.Resources>
        <syncTheme:SyncfusionThemeDictionary>
            <syncTheme:SyncfusionThemeDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <x:String x:Key="SfAIAssistViewResponseItemFontFamily">OpenSansRegular</x:String>
                </ResourceDictionary>
            </syncTheme:SyncfusionThemeDictionary.MergedDictionaries>
        </syncTheme:SyncfusionThemeDictionary>
    </ContentPage.Resources>

    <ContentPage.Content>
        <aiAssist:SfAIAssistView x:Name="sfAIAssistView"
                     AssistItems="{Binding AssistItems}"
                     Request="sfAIAssistView_Request"
                     Background="#f3e297" >
        </aiAssist:SfAIAssistView>
    </ContentPage.Content>

</ContentPage>