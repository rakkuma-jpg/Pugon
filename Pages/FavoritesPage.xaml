<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pugon.Pages.FavoritesPage"
             Title="My Favorites">
    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0"
          BackgroundColor="Transparent"
          ColumnDefinitions="*,Auto,*"
          Padding="0,10">

            <!-- Center title -->
            <Label Grid.Column="1"
               Text="Favorites"
               FontSize="26"
               FontAttributes="Bold"
               TextColor="#553600"
               HorizontalOptions="Center"
               VerticalOptions="Center"/>

            <!-- Right action -->
            <Label Grid.Column="2"
               Text="Sort"
               FontSize="20"
               FontAttributes="Bold"
               TextColor="#553600"
               HorizontalOptions="End"
               VerticalOptions="Center"
               Margin="0,0,16,0"/>
        </Grid>
    </Grid>


</ContentPage>