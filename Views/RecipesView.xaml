             x:Class="PugonPrototype.Views.RecipesView">
    <Border
        BackgroundColor="Transparent"
            Stroke="Transparent"
            StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="20,20,20,20" />
        </Border.StrokeShape>
        <VerticalStackLayout HorizontalOptions="Fill" BackgroundColor="Pink">
